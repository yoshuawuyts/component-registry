@schema {id crate:tracey-config@1, cli tracey}

specs (
    {
        name component-cli
        source_url https://github.com/yoshuawuyts/component-cli
        include (spec/**/*.md)
        impls (
            {
                name rust
                include (
                    crates/**/*.rs
                )
                exclude (
                    target/**
                )
                test_include (
                    crates/component-cli/tests/**/*.rs
                    crates/component-detector/tests/**/*.rs
                    crates/component-frontend/tests/**/*.rs
                    crates/component-tui/tests/**/*.rs
                    crates/**/src/**/tests.rs
                )
            }
        )
    }
)
